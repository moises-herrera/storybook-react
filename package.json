{
  "name": "mh-custom-components",
  "private": false,
  "version": "1.2.0",
  "type": "module",
  "main": "dist/src/index.js",
  "typings": "dist/src/index.d.ts",
  "keywords": [
    "react",
    "dev"
  ],
  "license": "MIT",
  "homepage": "https://github.com/moises-herrera/storybook-react#readme",
  "repository": {
    "url": "git+https://github.com/moises-herrera/storybook-react.git",
    "type": "git"
  },
  "files": [
    "dist/"
  ],
  "release": {
    "branches": [
      "main"
    ]
  },
  "engines": {
    "node": ">=12.0.0"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "scripts": {
    "dev": "pnpm run storybook",
    "build": "pnpm clean && tsc --build tsconfig.app.json && pnpm copy-assets",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "clean": "rimraf dist",
    "copy-assets": "copyfiles -u 1 src/**/*.css dist/src/",
    "push:npm": "np"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@storybook/addon-a11y": "^10.4.5",
    "@storybook/addon-docs": "^10.4.5",
    "@storybook/addon-onboarding": "^10.4.5",
    "@storybook/addon-vitest": "^10.4.5",
    "@storybook/react-vite": "^10.4.5",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "chromatic": "^17.4.1",
    "copyfiles": "^2.4.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.4.5",
    "globals": "^17.6.0",
    "np": "^11.2.1",
    "playwright": "^1.61.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rimraf": "^6.1.3",
    "storybook": "^10.4.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}
